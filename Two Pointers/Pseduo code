7. TRAPPING RAIN WATER
   Problem: Calculate trapped water between elevations
   Approach:
       left = 0, right = n-1
       leftMax = 0, rightMax = 0
       water = 0
       while left < right:
           if height[left] < height[right]:
               if height[left] >= leftMax:
                   leftMax = height[left]
               else:
                   water += leftMax - height[left]
               left++
           else:
               if height[right] >= rightMax:
                   rightMax = height[right]
               else:
                   water += rightMax - height[right]
               right--
       return water

8. MERGE SORTED ARRAY
   Problem: Merge two sorted arrays from the end
   Approach:
       p1 = m-1 (end of array1)
       p2 = n-1 (end of array2)
       p = m+n-1 (end of result)
       while p1 >= 0 AND p2 >= 0:
           if arr1[p1] > arr2[p2]:
               arr1[p] = arr1[p1]
               p1--
           else:
               arr1[p] = arr2[p2]
               p2--
           p--
       if p2 >= 0:
           copy remaining elements from arr2

9. LONGEST SUBSTRING WITHOUT REPEATING CHARS
   Problem: Find length of longest substring with unique chars
   Approach:
       left = 0, maxLen = 0
       charIndex = {} (hash map)
       for right = 0 to n-1:
           if char[right] in charIndex:
               left = max(left, charIndex[char[right]] + 1)
           charIndex[char[right]] = right
           maxLen = max(maxLen, right - left + 1)
       return maxLen

